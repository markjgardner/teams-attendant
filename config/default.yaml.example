azure:
  speech:
    key: "your-azure-speech-key"
    region: "eastus"
    voice: "en-US-JennyNeural"  # Azure TTS voice name
  foundry:
    endpoint: "https://your-foundry.azure.com"
    # api_key: "your-foundry-api-key"  # Optional: omit to use identity-based auth
    model_deployment: "claude-sonnet"

browser_data_dir: ".browser-data"
summaries_dir: "summaries"
default_profile: "balanced"

# Where to get meeting transcripts:
#   "auto"  - Try Teams live captions first, fall back to audio STT (default)
#   "ui"    - Only use Teams live captions (no Azure Speech needed)
#   "audio" - Only use Azure Speech-to-Text (original behavior)
transcript_source: "auto"

# Browser to use:
#   "chromium" - Bundled Chromium (default)
#   "msedge"   - System-installed Microsoft Edge
browser: "chromium"

# LLM API format: "anthropic" (Claude, Messages API) or "openai" (GPT, Chat Completions API)
# Both use the same Azure Foundry endpoint and credentials above.
# Set model_deployment to match your deployed model (e.g. "claude-sonnet" or "gpt-4o").
llm_provider: "anthropic"
